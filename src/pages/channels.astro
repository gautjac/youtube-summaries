---
import channelsData from '../data/channels.json';

const channels = (channelsData.channels || []).slice().sort((a, b) =>
  (a.name || '').localeCompare(b.name || '')
);
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Channels · YouTube Summaries</title>
  <meta name="theme-color" content="#0e0e10" />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Onest:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style is:global>
    :root {
      --bg: #0e0e10;
      --bg-lift: #141418;
      --text: #ece8e1;
      --text-mid: #8a857d;
      --text-dim: #4c4944;
      --hairline: rgba(236, 232, 225, 0.08);
      --hairline-strong: rgba(236, 232, 225, 0.18);
      --accent: #c9a674;
      --accent-dim: rgba(201, 166, 116, 0.15);

      --font-sans: 'Onest', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      --max-width: 720px;
      --page-pad: 28px;
      --kicker-tracking: 0.16em;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { background: var(--bg); color: var(--text); }
    body {
      font-family: var(--font-sans);
      font-size: 15px; line-height: 1.62;
      -webkit-font-smoothing: antialiased;
      padding: 56px var(--page-pad) 140px;
      min-height: 100vh;
    }
    .container { max-width: var(--max-width); margin: 0 auto; }
    ::selection { background: var(--accent-dim); color: var(--text); }

    header { margin-bottom: 56px; }
    header .kicker {
      font-size: 11px; font-weight: 500;
      letter-spacing: var(--kicker-tracking);
      text-transform: uppercase;
      color: var(--text-mid);
    }
    header h1 { margin-top: 4px; font-size: 26px; font-weight: 600; letter-spacing: -0.02em; }
    header p { margin-top: 8px; font-size: 13px; color: var(--text-mid); }
    header nav {
      margin-top: 22px;
      display: flex; gap: 18px;
      font-size: 11px;
      letter-spacing: var(--kicker-tracking);
      text-transform: uppercase;
    }
    header nav a {
      color: var(--text-mid); text-decoration: none;
      border-bottom: 1px solid transparent;
      padding-bottom: 2px;
      transition: color 180ms, border-color 180ms;
    }
    header nav a:hover { color: var(--text); }
    header nav a.current { color: var(--text); border-bottom-color: var(--text); }

    .add-row { margin-bottom: 40px; display: flex; gap: 10px; align-items: center; }
    .add-btn, .pill-btn {
      background: none;
      border: 1px solid var(--hairline-strong);
      color: var(--text);
      padding: 9px 18px;
      font: inherit;
      font-size: 11px;
      letter-spacing: var(--kicker-tracking);
      text-transform: uppercase;
      cursor: pointer;
      text-decoration: none;
      transition: border-color 180ms, color 180ms;
    }
    .add-btn:hover, .pill-btn:hover { border-color: var(--text-mid); color: var(--text); }
    .add-btn[disabled] { opacity: 0.5; cursor: progress; }
    .count { font-size: 11px; color: var(--text-mid); text-transform: uppercase; letter-spacing: var(--kicker-tracking); }

    .channel-list { display: flex; flex-direction: column; gap: 0; }
    .channel-row {
      display: grid;
      grid-template-columns: 48px 1fr auto;
      gap: 16px;
      align-items: center;
      padding: 18px 0;
      border-bottom: 1px solid var(--hairline);
    }
    .channel-avatar {
      width: 48px; height: 48px; border-radius: 50%;
      overflow: hidden;
      background: var(--bg-lift);
      flex-shrink: 0;
    }
    .channel-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .channel-info { min-width: 0; }
    .channel-name {
      font-size: 15px; font-weight: 600;
      color: var(--text);
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .channel-sub {
      font-size: 11px;
      color: var(--text-mid);
      letter-spacing: 0.02em;
      margin-top: 2px;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .channel-actions { display: flex; gap: 8px; align-items: center; }
    .icon-btn {
      background: none; border: none;
      color: var(--text-dim);
      font: inherit; font-size: 11px;
      letter-spacing: var(--kicker-tracking);
      text-transform: uppercase;
      cursor: pointer;
      padding: 6px 8px;
      transition: color 180ms;
    }
    .icon-btn:hover { color: var(--text); }
    .icon-btn.danger:hover { color: var(--accent); }

    .empty {
      padding: 80px 0; text-align: center; color: var(--text-mid);
    }
    .empty h2 { font-size: 18px; color: var(--text); margin-bottom: 12px; }
    .empty p { font-size: 13px; max-width: 440px; margin: 0 auto; }

    /* Modal */
    .modal {
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.7);
      display: none;
      align-items: center; justify-content: center;
      padding: 28px;
      z-index: 50;
    }
    .modal.open { display: flex; }
    .modal-card {
      background: var(--bg-lift);
      border: 1px solid var(--hairline-strong);
      border-radius: 6px;
      padding: 28px;
      width: 100%;
      max-width: 440px;
      max-height: 86vh;
      overflow-y: auto;
    }
    .modal-card h2 {
      font-size: 11px; font-weight: 500;
      letter-spacing: var(--kicker-tracking);
      text-transform: uppercase;
      color: var(--text-mid);
      margin-bottom: 18px;
    }
    .modal-card label {
      display: block;
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-mid);
      margin: 14px 0 6px;
    }
    .modal-card input[type="text"], .modal-card input[type="number"], .modal-card textarea {
      width: 100%;
      background: transparent;
      border: 1px solid var(--hairline-strong);
      color: var(--text);
      padding: 9px 12px;
      font: inherit;
      font-size: 13px;
      border-radius: 3px;
      outline: none;
      transition: border-color 180ms;
    }
    .modal-card input:focus, .modal-card textarea:focus { border-color: var(--text-mid); }
    .modal-card textarea { resize: vertical; min-height: 60px; }
    .modal-card .field-hint { font-size: 10px; color: var(--text-dim); margin-top: 4px; }
    .modal-card .checkbox-row {
      display: flex; gap: 10px; align-items: center;
      margin: 14px 0 6px;
    }
    .modal-card .checkbox-row label {
      margin: 0; text-transform: none; letter-spacing: 0;
      font-size: 13px; color: var(--text);
    }
    .modal-actions {
      margin-top: 22px;
      display: flex; gap: 10px; justify-content: flex-end;
    }
    .lookup-row { display: flex; gap: 8px; align-items: stretch; }
    .lookup-row input { flex: 1; }
    .status {
      font-size: 11px;
      color: var(--text-mid);
      margin-top: 8px;
      min-height: 1.2em;
    }
    .status.error { color: #e35d5d; }

    .toast {
      position: fixed; bottom: 24px; left: 50%;
      transform: translateX(-50%);
      background: var(--bg-lift);
      border: 1px solid var(--hairline-strong);
      color: var(--text);
      padding: 10px 18px;
      font-size: 12px;
      border-radius: 4px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 240ms;
      z-index: 60;
    }
    .toast.show { opacity: 1; }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <span class="kicker">Catalog</span>
      <h1>Channels</h1>
      <p>Tracked YouTube channels. Each one is polled for new videos that pass the filters.</p>
      <nav>
        <a href="/">Feed</a>
        <a href="/channels" class="current">Channels</a>
        <a href="/watched">Watched</a>
      </nav>
    </header>

    <div class="add-row">
      <button class="add-btn" id="add-btn">+ Add channel</button>
      <span class="count" id="count">{channels.length} channel{channels.length === 1 ? '' : 's'}</span>
    </div>

    <div class="channel-list" id="channel-list">
      {channels.length === 0 ? (
        <div class="empty">
          <h2>No channels yet.</h2>
          <p>Click "+ Add channel" and paste a YouTube channel URL, an <code>@handle</code>, or a <code>UC...</code> id. The lookup runs against YouTube's public pages — no API key, no quota.</p>
        </div>
      ) : channels.map(c => (
        <div class="channel-row" data-channel-id={c.id}>
          <div class="channel-avatar">
            {c.icon && <img src={c.icon} alt="" loading="lazy" />}
          </div>
          <div class="channel-info">
            <div class="channel-name">{c.name}</div>
            <div class="channel-sub">
              {c.handle || c.id} · min {Math.round((c.minLengthSec || 300) / 60)}m
              {c.skipReuploads ? ' · skips re-uploads' : ''}
            </div>
          </div>
          <div class="channel-actions">
            {c.url && <a class="icon-btn" href={c.url} target="_blank" rel="noopener">Open</a>}
            <button class="icon-btn" data-action="edit" data-channel-id={c.id}>Edit</button>
            <button class="icon-btn danger" data-action="delete" data-channel-id={c.id}>Remove</button>
          </div>
        </div>
      ))}
    </div>

    <!-- Add / Edit modal -->
    <div class="modal" id="modal" role="dialog" aria-modal="true">
      <div class="modal-card">
        <h2 id="modal-title">Add channel</h2>

        <label>Channel URL, @handle, or UC… id</label>
        <div class="lookup-row">
          <input type="text" id="lookup-input" placeholder="@veritasium or https://www.youtube.com/@kurzgesagt" autocomplete="off" />
          <button class="pill-btn" id="lookup-btn">Look up</button>
        </div>
        <div class="status" id="lookup-status"></div>

        <label>Name</label>
        <input type="text" id="field-name" autocomplete="off" />

        <label>Channel ID (UC…)</label>
        <input type="text" id="field-id" autocomplete="off" />

        <label>Handle (e.g. @veritasium)</label>
        <input type="text" id="field-handle" autocomplete="off" />

        <label>Icon URL</label>
        <input type="text" id="field-icon" autocomplete="off" />

        <label>Description</label>
        <textarea id="field-description"></textarea>

        <label>Minimum video length (minutes)</label>
        <input type="number" id="field-min-length" min="1" max="240" step="1" value="5" />
        <div class="field-hint">Videos shorter than this are skipped.</div>

        <div class="checkbox-row">
          <input type="checkbox" id="field-skip-reuploads" />
          <label for="field-skip-reuploads">Skip "Best of" / compilation / re-upload titles</label>
        </div>

        <div class="status" id="save-status"></div>
        <div class="modal-actions">
          <button class="pill-btn" id="cancel-btn">Cancel</button>
          <button class="pill-btn" id="save-btn">Save</button>
        </div>
      </div>
    </div>

    <div class="toast" id="toast"></div>
  </div>

  <script is:inline>
    const FIREBASE_API_KEY = 'AIzaSyDBLCnPauZJeg2JGriKp9KM-QFjYmSf12s';
    const FIREBASE_PROJECT = 'charlotte-dashboard';
    const COLLECTION = 'youtube_channels';
    const FIRESTORE_BASE = `https://firestore.googleapis.com/v1/projects/${FIREBASE_PROJECT}/databases/(default)/documents`;

    const modal = document.getElementById('modal');
    const lookupInput = document.getElementById('lookup-input');
    const lookupBtn = document.getElementById('lookup-btn');
    const lookupStatus = document.getElementById('lookup-status');
    const fields = {
      name: document.getElementById('field-name'),
      id: document.getElementById('field-id'),
      handle: document.getElementById('field-handle'),
      icon: document.getElementById('field-icon'),
      description: document.getElementById('field-description'),
      minLength: document.getElementById('field-min-length'),
      skipReuploads: document.getElementById('field-skip-reuploads'),
    };
    const saveBtn = document.getElementById('save-btn');
    const saveStatus = document.getElementById('save-status');
    let editingId = null;

    function showToast(msg) {
      const el = document.getElementById('toast');
      el.textContent = msg;
      el.classList.add('show');
      clearTimeout(showToast._t);
      showToast._t = setTimeout(() => el.classList.remove('show'), 1800);
    }

    function openModal(channel) {
      editingId = channel?.id || null;
      document.getElementById('modal-title').textContent = channel ? 'Edit channel' : 'Add channel';
      lookupInput.value = '';
      lookupStatus.textContent = '';
      saveStatus.textContent = '';
      saveStatus.classList.remove('error');
      fields.name.value = channel?.name || '';
      fields.id.value = channel?.id || '';
      fields.handle.value = channel?.handle || '';
      fields.icon.value = channel?.icon || '';
      fields.description.value = channel?.description || '';
      fields.minLength.value = String(Math.round((channel?.minLengthSec || 300) / 60));
      fields.skipReuploads.checked = !!channel?.skipReuploads;
      modal.classList.add('open');
      setTimeout(() => lookupInput.focus(), 30);
    }
    function closeModal() {
      modal.classList.remove('open');
      editingId = null;
    }
    document.getElementById('add-btn').addEventListener('click', () => openModal());
    document.getElementById('cancel-btn').addEventListener('click', closeModal);
    modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });

    document.getElementById('channel-list').addEventListener('click', async e => {
      const btn = e.target.closest('[data-action]');
      if (!btn) return;
      const id = btn.dataset.channelId;
      if (btn.dataset.action === 'edit') {
        // Pull the channel from the embedded data via data-* + dataset would
        // be cleaner; this fetches the doc to ensure freshness.
        try {
          const res = await fetch(`${FIRESTORE_BASE}/${COLLECTION}/${id}?key=${FIREBASE_API_KEY}`);
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
          const doc = await res.json();
          const f = doc.fields || {};
          openModal({
            id,
            name: f.name?.stringValue || '',
            handle: f.handle?.stringValue || '',
            icon: f.icon?.stringValue || '',
            description: f.description?.stringValue || '',
            minLengthSec: f.minLengthSec?.integerValue ? parseInt(f.minLengthSec.integerValue, 10) : 300,
            skipReuploads: !!f.skipReuploads?.booleanValue,
          });
        } catch (err) {
          showToast('Could not load channel');
        }
      } else if (btn.dataset.action === 'delete') {
        if (!confirm('Remove this channel from the catalog?')) return;
        try {
          const res = await fetch(`${FIRESTORE_BASE}/${COLLECTION}/${id}?key=${FIREBASE_API_KEY}`, { method: 'DELETE' });
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
          showToast('Removed');
          setTimeout(() => location.reload(), 600);
        } catch (err) {
          showToast('Delete failed');
        }
      }
    });

    lookupBtn.addEventListener('click', async () => {
      const q = lookupInput.value.trim();
      if (!q) { lookupStatus.textContent = 'Paste a channel URL, @handle, or UC… id.'; return; }
      lookupBtn.disabled = true;
      lookupStatus.textContent = 'Looking up…';
      lookupStatus.classList.remove('error');
      try {
        const res = await fetch(`/.netlify/functions/channel-lookup?query=${encodeURIComponent(q)}`);
        if (!res.ok) {
          const errText = await res.text();
          throw new Error(errText || `HTTP ${res.status}`);
        }
        const data = await res.json();
        fields.name.value = data.name || '';
        fields.id.value = data.id || '';
        fields.handle.value = data.handle || '';
        fields.icon.value = data.icon || '';
        fields.description.value = data.description || '';
        lookupStatus.textContent = 'Found. Review and save.';
      } catch (err) {
        lookupStatus.classList.add('error');
        lookupStatus.textContent = err.message || 'Lookup failed';
      } finally {
        lookupBtn.disabled = false;
      }
    });

    saveBtn.addEventListener('click', async () => {
      const id = (fields.id.value || '').trim();
      const name = (fields.name.value || '').trim();
      if (!id.startsWith('UC')) {
        saveStatus.classList.add('error');
        saveStatus.textContent = 'Channel ID must be a UC… id.';
        return;
      }
      if (!name) {
        saveStatus.classList.add('error');
        saveStatus.textContent = 'Name is required.';
        return;
      }
      saveStatus.classList.remove('error');
      saveStatus.textContent = 'Saving…';
      saveBtn.disabled = true;

      const minMinutes = Math.max(1, parseInt(fields.minLength.value, 10) || 5);
      const payload = {
        fields: {
          name: { stringValue: name },
          handle: { stringValue: (fields.handle.value || '').trim() },
          icon: { stringValue: (fields.icon.value || '').trim() },
          description: { stringValue: (fields.description.value || '').trim() },
          url: { stringValue: fields.handle.value
            ? `https://www.youtube.com/${fields.handle.value.trim()}`
            : `https://www.youtube.com/channel/${id}` },
          feedUrl: { stringValue: `https://www.youtube.com/feeds/videos.xml?channel_id=${id}` },
          minLengthSec: { integerValue: String(minMinutes * 60) },
          skipReuploads: { booleanValue: fields.skipReuploads.checked },
          addedAt: { timestampValue: new Date().toISOString() },
        },
      };

      try {
        // Create-if-missing, then update on 409.
        const createUrl = `${FIRESTORE_BASE}/${COLLECTION}?documentId=${encodeURIComponent(id)}&key=${FIREBASE_API_KEY}`;
        let res = await fetch(createUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok && res.status === 409) {
          const updateUrl = `${FIRESTORE_BASE}/${COLLECTION}/${encodeURIComponent(id)}?key=${FIREBASE_API_KEY}`;
          res = await fetch(updateUrl, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
        }
        if (!res.ok) {
          const txt = await res.text();
          throw new Error(txt || `HTTP ${res.status}`);
        }
        showToast('Saved');
        closeModal();
        setTimeout(() => location.reload(), 700);
      } catch (err) {
        saveStatus.classList.add('error');
        saveStatus.textContent = err.message || 'Save failed';
      } finally {
        saveBtn.disabled = false;
      }
    });
  </script>
</body>
</html>
